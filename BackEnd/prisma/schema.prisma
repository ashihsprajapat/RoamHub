generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String    @id @default(uuid())
  name                String
  email               String    @unique
  password            String
  verify              Boolean   @default(false)
  otp                 String?
  vlidTime            DateTime?
  totalPublicListings Int       @default(0)
  totalBookings       Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @default(now()) @updatedAt
  phoneNumber         String?   @unique
  isPhoneVerified     Boolean   @default(false)
  phoneOtp            String?
  phoneValidTime      DateTime?
  bookings            Booking[]
  reviews             Review[]
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String   @db.VarChar(500)
  userId    String
  listingId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Transaction {
  id            String        @id @default(uuid())
  paymentStatus PaymentStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @default(now()) @updatedAt
  order_id      String?
  totalAmount   Decimal       @db.Decimal(10, 2)
  paymentType   String?
  userId        String
  listingId     String
  booking       Booking?
}

model Guest {
  id         String  @id @default(uuid())
  name       String
  age        Int
  gender     String
  adharLast4 String?
  bookingId  String
  booking    Booking @relation(fields: [bookingId], references: [id])
}

model Booking {
  id             String        @id @default(uuid())
  ownerId        String
  listingId      String
  from           DateTime?
  to             DateTime?
  paymentStatus  PaymentStatus @default(PENDING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @default(now()) @updatedAt
  TotalNights    Int
  pernightCharge Int
  totalAmount    Decimal       @db.Decimal(10, 2)
  transactionId  String        @unique
  listingAddress String        @default("")
  listingImage   String        @default("")
  listingTitle   String        @default("")
  user           User          @relation(fields: [ownerId], references: [id])
  transaction    Transaction   @relation(fields: [transactionId], references: [id])
  guests         Guest[]
}

model playing_with_neon {
  id    Int    @id @default(autoincrement())
  name  String
  value Float? @db.Real
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}
